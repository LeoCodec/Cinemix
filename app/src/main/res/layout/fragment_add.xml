<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Selector tipo -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleTipo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <Button android:id="@+id/btnPelicula"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:text="🎬 Película"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp"/>

            <Button android:id="@+id/btnSerie"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:text="📺 Serie"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp"/>

            <Button android:id="@+id/btnLibro"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:text="📚 Libro"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp"/>

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- Portada -->
        <ImageView
            android:id="@+id/imgPortada"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            android:background="#1a1a22"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnPortada"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Subir portada (PNG / JPG)"
            android:layout_marginBottom="16dp"/>

        <!-- Título -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Título"
            android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Director -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Director (películas / series)"
            android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDirector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Autor -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Autor (libros)"
            android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAutor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Año -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Año"
            android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAnio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Género -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Género"
            android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etGenero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Veces visto -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Veces visto"
            android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etVeces"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Sinopsis -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Sinopsis"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSinopsis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="3"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Rating -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tu calificación:"
            android:layout_marginBottom="4dp"/>

        <RatingBar
            android:id="@+id/ratingBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:stepSize="0.5"
            android:layout_marginBottom="12dp"/>

        <!-- Favorito -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchFavorito"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="¿Es tu favorita?"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnGuardar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Guardar en mi colección"/>

    </LinearLayout>
</ScrollView>
